<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:startDestination="@id/onboardFragment">

    <!-- Define the fragment you want to navigate to -->
    <fragment
        android:id="@+id/onboardFragment"
        android:name="com.isyara.app.ui.onboard.OnboardFragment"
        android:label="Translate"
        tools:layout="@layout/fragment_onboard">
        <action
            android:id="@+id/action_onboardFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/slide_down"
            app:popEnterAnim="@anim/slide_up"
            app:popExitAnim="@anim/slide_down" />
        <action
            android:id="@+id/action_onboardFragment_to_signupFragment"
            app:destination="@id/signupFragment"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/slide_down"
            app:popEnterAnim="@anim/slide_up"
            app:popExitAnim="@anim/slide_down" />
        <action
            android:id="@+id/action_onboardFragment_to_homeScreenFragment"
            app:destination="@id/homeScreenFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.isyara.app.ui.loginandsignup.LoginFragment"
        android:label="Translate"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_homeScreenFragment"
            app:destination="@id/homeScreenFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
        <action
            android:id="@+id/action_loginFragment_to_signupFragment"
            app:destination="@id/signupFragment"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/slide_down"
            app:popEnterAnim="@anim/slide_up"
            app:popExitAnim="@anim/slide_down" />
    </fragment>

    <fragment
        android:id="@+id/signupFragment"
        android:name="com.isyara.app.ui.loginandsignup.SignUpFragment"
        android:label="Translate"
        tools:layout="@layout/fragment_signup">
        <action
            android:id="@+id/action_signupFragment_to_homeScreenFragment"
            app:destination="@id/homeScreenFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
        <action
            android:id="@+id/action_signupFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/slide_down"
            app:popEnterAnim="@anim/slide_up"
            app:popExitAnim="@anim/slide_down" />
    </fragment>

    <fragment
        android:id="@+id/homeScreenFragment"
        android:name="com.isyara.app.ui.homescreen.HomeScreenFragment"
        android:label="Home Screen"
        tools:layout="@layout/fragment_home_screen">
        <action
            android:id="@+id/action_homeScreenFragment_to_translateFragment"
            app:destination="@id/translateFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
        <action
            android:id="@+id/action_homeScreenFragment_to_dictionaryFragment"
            app:destination="@id/dictionaryFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
        <action
            android:id="@+id/action_homeScreenFragment_to_quizFragment"
            app:destination="@id/quizFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
        <action
            android:id="@+id/action_homeScreenFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
        <action
            android:id="@+id/action_homeScreenFragment_to_settingsFragment"
            app:destination="@id/settingsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
        <action
            android:id="@+id/action_homeScreenFragment_to_speakFragment"
            app:destination="@id/speakFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
    </fragment>

    <fragment
        android:id="@+id/translateFragment"
        android:name="com.isyara.app.ui.translate.TranslateFragment"
        android:label="Translate"
        tools:layout="@layout/fragment_translate" />

    <fragment
        android:id="@+id/dictionaryFragment"
        android:name="com.isyara.app.ui.dictionary.DictionaryFragment"
        android:label="Translate"
        tools:layout="@layout/fragment_dictionary">
        <action
            android:id="@+id/action_dictionaryFragment_to_dictionaryWordFragment"
            app:destination="@id/dictionaryWordFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
        <action
            android:id="@+id/action_dictionaryFragment_to_dictionarySentenceFragment"
            app:destination="@id/dictionarySentenceFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_left" />
    </fragment>

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.isyara.app.ui.quiz.QuizFragment"
        android:label="Quiz"
        tools:layout="@layout/fragment_quiz">
        <action
            android:id="@+id/action_quizFragment_to_inGameFragment"
            app:destination="@id/inGameFragment" />
        <action
            android:id="@+id/action_quizFragment_to_onboardFragment"
            app:destination="@id/onboardFragment" />
        <action
            android:id="@+id/action_quizFragment_to_inGameFragment2"
            app:destination="@id/inGameFragment" />
    </fragment>

    <fragment
        android:id="@+id/inGameFragment"
        android:name="com.isyara.app.ui.quiz.ingame.InGameFragment"
        android:label="InGame"
        tools:layout="@layout/fragment_in_game">
        <action
            android:id="@+id/action_inGameFragment_to_questionFragment"
            app:destination="@id/questionFragment" />
    </fragment>

    <fragment
        android:id="@+id/questionFragment"
        android:name="com.isyara.app.ui.quiz.question.QuestionFragment"
        android:label="Question"
        tools:layout="@layout/fragment_question">
        <action
            android:id="@+id/action_questionFragment_to_passResultFragment"
            app:destination="@id/passResultFragment" />
        <action
            android:id="@+id/action_questionFragment_to_failedResultFragment"
            app:destination="@id/failedResultFragment" />
        <action
            android:id="@+id/action_questionFragment_to_onboardFragment"
            app:destination="@id/onboardFragment" />
        <action
            android:id="@+id/action_questionFragment_self"
            app:destination="@id/questionFragment" />
    </fragment>

    <fragment
        android:id="@+id/passResultFragment"
        android:name="com.isyara.app.ui.quiz.result.pass.PassResultFragment"
        android:label="Pass Result"
        tools:layout="@layout/fragment_pass_result">
        <action
            android:id="@+id/action_passResultFragment_to_quizFragment"
            app:destination="@id/quizFragment" />
    </fragment>

    <fragment
        android:id="@+id/failedResultFragment"
        android:name="com.isyara.app.ui.quiz.result.failed.FailedResultFragment"
        android:label="Failed Result"
        tools:layout="@layout/fragment_failed_result">
        <action
            android:id="@+id/action_failedResultFragment_to_quizFragment"
            app:destination="@id/quizFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.isyara.app.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settingsFragment_to_onboardFragment"
            app:destination="@id/onboardFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/fade_out" />
        <action
            android:id="@+id/action_settingsFragment_to_profileFragment"
            app:destination="@id/profileFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/fade_out" />
        <action
            android:id="@+id/action_settingsFragment_to_scoreFragment"
            app:destination="@id/scoreFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/fade_out" />
        <action
            android:id="@+id/action_settingsFragment_to_resourceFragment"
            app:destination="@id/resourceFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/resourceFragment"
        android:name="com.isyara.app.ui.resource.ResourceFragment"
        android:label="Resource"
        tools:layout="@layout/fragment_resource" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.isyara.app.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profileFragment_to_onboardFragment"
            app:destination="@id/onboardFragment"
            app:popUpTo="@id/onboardFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/scoreFragment"
        android:name="com.isyara.app.ui.score.ScoreFragment"
        android:label="Quiz Scores"
        tools:layout="@layout/fragment_score" />

    <fragment
        android:id="@+id/dictionaryWordFragment"
        android:name="com.isyara.app.ui.dictionary_word.DictionaryWordFragment"
        android:label="DictionaryWord"
        tools:layout="@layout/fragment_dictionary_word">
        <action
            android:id="@+id/action_dictionaryWordFragment_to_dictionaryFragment"
            app:destination="@id/dictionaryFragment" />
    </fragment>

    <fragment
        android:id="@+id/dictionarySentenceFragment"
        android:name="com.isyara.app.ui.dictionary_sentence.DictionarySentenceFragment"
        android:label="DictionarySentence"
        tools:layout="@layout/fragment_dictionary_sentence">
        <action
            android:id="@+id/action_dictionarySentenceFragment_to_dictionaryFragment"
            app:destination="@id/dictionaryFragment" />
    </fragment>

    <fragment
        android:id="@+id/speakFragment"
        android:name="com.isyara.app.ui.speak.SpeakFragment"
        android:label="Belajar Berbicara"
        tools:layout="@layout/fragment_speak">
        <action
            android:id="@+id/action_speakFragment_to_speakAddFragment"
            app:destination="@id/speakAddFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/fade_out" />
        <action
            android:id="@+id/action_speakFragment_to_speakPracticeFragment"
            app:destination="@id/speakPracticeFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/speakAddFragment"
        android:name="com.isyara.app.ui.speak.add.SpeakAddFragment"
        android:label="Tambah Latihan Bicara"
        tools:layout="@layout/fragment_speak_add" />

    <fragment
        android:id="@+id/speakPracticeFragment"
        android:name="com.isyara.app.ui.speak.practice.SpeakPracticeFragment"
        android:label="Praktek Bicara"
        tools:layout="@layout/fragment_speak_practice">
        <argument
            android:name="itemId"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>

</navigation>
